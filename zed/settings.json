{
  "agent_ui_font_size": 14.0,
  "ui_font_size": 14.0,
  "buffer_font_size": 14.0,
  "ssh_connections": [
    {
      "host": "arch.falcon-court.ts.net",
      "args": [],
      "nickname": "arch",
    },
  ],
  "edit_predictions": {
    "provider": "zed",
  },
  "scrollbar": {
    "show": "never",
  },
  "soft_wrap": "editor_width",
  "relative_line_numbers": "enabled",
  "which_key": {
    "enabled": true,
  },
  "terminal": {
    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "base_keymap": "VSCode",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "JetBrains Dark",
  },
  "auto_install_extensions": {
    "catppuccin-blur": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "jetbrains-themes": true,
    "latex": true,
    "ltex": true,
    "lua": true,
    "macos-classic": true,
    "make": true,
    "toml": true,
    "typst": true,
    "ultimate-dark-neo": true,
  },
  "lsp": {
    "tinymist": {
      "settings": {
        "exportPdf": "onType",
        "outputPath": "$root/$name",
      },
    },
  },
}
